<% layout("/layouts/boilerplate") %>
<div class="page-shell">
  <div class="edit-card">
    <div class="music-head">
      <div class="music-title">
        <h1>New Song</h1>
        <p>Add a new track to your pink-and-black music collection.</p>
      </div>
      <div class="music-animation" aria-hidden="true">
        <span class="note note-1"></span>
        <span class="note note-2"></span>
        <span class="note note-3"></span>
      </div>
    </div>
    <form action="/home" method="POST" class="needs-validation edit-form" novalidate>
      <div class="mb-3 input-group-custom">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="title" id="title" class="form-control" placeholder="Enter your title" required>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="mb-3 input-group-custom">
        <label for="description" class="form-label">Description</label>
        <input type="text" name="description" id="description" class="form-control" placeholder="Enter your description" required>
        <div class="invalid-feedback">Please enter a description.</div>
      </div>
      
      <div class="mb-3 input-group-custom">
        <label for="thumbnail" class="form-label">Thumbnail</label>
        <input type="text" name="thumbnail" id="thumbnail" class="form-control" placeholder="Enter your thumbnail link" required>
        <div class="invalid-feedback">Please enter a thumbnail link.</div>
      </div>

      <div class="mb-4 input-group-custom">
        <label for="song" class="form-label">Song</label>
        <input type="text" name="song" id="song" class="form-control" placeholder="Enter your song link" required>
        <div class="invalid-feedback">Please enter a song link.</div>
      </div>

      <button type="submit" class="btn btn-dark btn-lg btn-block">Submit</button>
    </form>
  </div>
</div>
