<%- layout("/layouts/boilerplate") %>
    <h1>New Song</h1>
    <form action="/home" method="POST" class="needs-validation" novalidate>
        <div>
        <label for="title">Title</label>
        <input type="text" name="title" id="title" placeholder="Enter your title" required>
        <div class="invalid-feedback">Please enter a title.</div>
        <div class="valid-feedback">Looks good!</div>
        </div>

        <div>

        <label for="description">Description</label>
        <input type="text" name="description" id="description" placeholder="Enter your description" required>
        <div class="invalid-feedback">Please enter a description.</div>
        <div class="valid-feedback">Looks good!</div>
        </div>
        
        <div>
        <label for="thumbnail">Thumbnail</label>
        <input type="text" name="thumbnail" id="thumbnail" placeholder="Enter your thumbnail link" required>
        <div class="invalid-feedback">Please enter a thumbnail link.</div>
        <div class="valid-feedback">Looks good!</div>
        </div>

        <div>
        <label for="song">Song</label>
        <input type="text" name="song" id="song" placeholder="enter your song link" required>
        <div class="invalid-feedback">Please enter a song link.</div>
        <div class="valid-feedback">Looks good!</div>
        </div>

        <button>Submit</button>
    </form>
