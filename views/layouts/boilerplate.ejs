<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <title>Document</title>
</head>
<body>
    <%- include ("../includes/navbar.ejs") %>
    <div class="container"><%-body%></div>
    <%- include('../includes/footer') %>
    
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (() => {
        'use strict'

        const forms = document.querySelectorAll('.needs-validation')
        const body = document.body

        function animateSubmit(form) {
          const burst = document.createElement('div')
          burst.className = 'submit-burst'
          const offsets = [
            { x: -20, y: -70 },
            { x: 18, y: -90 },
            { x: 40, y: -65 },
            { x: -34, y: -50 },
            { x: 52, y: -88 },
            { x: 24, y: -120 },
            { x: -10, y: -100 },
            { x: 68, y: -55 }
          ]

          offsets.forEach((offset, index) => {
            const note = document.createElement('span')
            note.className = `burst-note burst-note-${index + 1}`
            note.style.setProperty('--dx', `${offset.x}px`)
            note.style.setProperty('--dy', `${offset.y}px`)
            burst.appendChild(note)
          })

          form.appendChild(burst)
          requestAnimationFrame(() => burst.classList.add('animate'))
          setTimeout(() => burst.remove(), 1200)
        }

        function startPageTransition() {
          body.classList.remove('page-exit')
          body.classList.add('page-enter')
        }

        function setupPageLinks() {
          const links = Array.from(document.querySelectorAll('a[href]'))
            .filter(link => {
              const url = new URL(link.href, window.location.origin)
              return url.origin === window.location.origin && !link.target && !link.href.startsWith('#')
            })

          links.forEach(link => {
            link.addEventListener('click', event => {
              event.preventDefault()
              body.classList.add('page-exit')
              setTimeout(() => window.location.href = link.href, 240)
            })
          })
        }

        function initValidation() {
          Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
              if (!form.checkValidity()) {
                event.preventDefault()
                event.stopPropagation()
                form.classList.add('was-validated')
                return
              }

              event.preventDefault()
              form.classList.add('was-validated')
              animateSubmit(form)
              setTimeout(() => form.submit(), 350)
            }, false)
          })
        }

        document.addEventListener('DOMContentLoaded', () => {
          startPageTransition()
          setupPageLinks()
          initValidation()
        })
      })()
    </script>
</body>
</html>