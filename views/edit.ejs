<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit Route</h1>
    <form action="/show/<%=songDetails._id%>?_method=PUT" method="POST">
    <input type="text" name="title" value="<%=songDetails.title%>">
    <input type="text" name="description" value="<%=songDetails.description%>">
    <input type="text" name="thumbnail" value="<%=songDetails.thumbnail%>">
    <input type="text" name="song" value="<%=songDetails.song%>">
    <button>Edit</button>
    </form>
</body>
</html>